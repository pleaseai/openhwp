# Deno
# Anchored to the repo root so it only ignores Deno's top-level `deno vendor`
# output, not the intentionally committed engine at src/ui/vendor/rhwp.
/vendor/
node_modules/

# Build output — deno desktop binaries and installers
build/
dist/
*.app/
*.dmg
*.msi
*.deb
*.rpm
*.AppImage
*.exe

# Environment
.env
.env.local
.env.*.local

# Claude Code local settings (merged shared config; copied into worktrees)
.claude/settings.local.json

# run-openhwp driver artifacts (regenerated on each run)
.claude/skills/run-openhwp/screenshots/

# OS / editor noise
.DS_Store
Thumbs.db
*.swp
.idea/
.vscode/
